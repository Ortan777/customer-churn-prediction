# .ebextensions/01_packages.config
# AWS Elastic Beanstalk configuration for the Docker platform
# This file configures environment settings for the EB deployment

option_settings:
  aws:elasticbeanstalk:application:environment:
    PORT: "8000"
    PYTHONUNBUFFERED: "1"
    # Set your S3 bucket for model artifacts:
    # AWS_S3_BUCKET: "your-churn-model-bucket"
    # AWS_REGION: "us-east-1"

  aws:elasticbeanstalk:environment:proxy:
    ProxyServer: nginx

  aws:autoscaling:launchconfiguration:
    InstanceType: t3.small

  aws:autoscaling:asg:
    MinSize: "1"
    MaxSize: "2"

  aws:elasticbeanstalk:environment:
    EnvironmentType: LoadBalanced
    LoadBalancerType: application
